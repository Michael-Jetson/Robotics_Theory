% figs.sty -- figure library bundle for INLINE TikZ figures in the book.
% Loaded by common/preamble.tex via \usepackage{figs}. Adds the extra TikZ
% libraries + pgfplots / pgfgantt / tikz-3dplot / bayesnet on top of what the
% preamble already loads, plus a few shared drawing styles. Also usable by the
% standalone figures in figures/src/ (compile with the project root on TEXINPUTS).
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{figs}[2026/06/16 Robotics Note figure bundle]

\RequirePackage{tikz}
\usetikzlibrary{%
  3d, positioning, calc, intersections, arrows.meta,%
  decorations.pathreplacing, decorations.markings, angles, quotes,%
  shapes.geometric, fit, backgrounds, spy, matrix, patterns, bending}
\RequirePackage{tikz-3dplot}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}
\RequirePackage{pgfgantt}
% factor graphs / Bayesian networks (ships with TeX Live full):
\usetikzlibrary{bayesnet}

% ---- shared drawing styles (use inline in the book) ----
\tikzset{
  vec/.style       ={-{Stealth[length=3mm]}, thick},  % arrow-headed vector
  axisarrow/.style ={->, thick},                       % plain axis arrow
}

% ---- 知识导航树: forest 自适应布局 ----
% 替代手工定位 TikZ 流程图(易重叠/连线穿框)。forest 自动算间距(l sep/s sep)、
% 兄弟子树不重叠、边走 parent.south->child.north 不穿框。按层自动配色。
% 用法(节点文字含逗号/方括号/数学 一律 {} 包):
%   \begin{center}\begin{forest} navtree
%   [{根\\副标题}
%     [{支柱A\\说明} [{叶}] ]
%     [{支柱B} [{叶1}][{叶2}] ]
%   ]
%   \end{forest}\end{center}
\RequirePackage{forest}
\forestset{
  navtree/.style={
    for tree={
      draw, rounded corners, align=center, font=\small, inner sep=3pt,
      edge={->, thick, gray!60!black},
      parent anchor=south, child anchor=north,
      l sep=8mm, s sep=5mm,
    },
    where level=0{fill=main!6,  draw=main!60!black}{},
    where level=1{fill=second!6, draw=second!60!black}{},
    where level>=2{fill=third!8, draw=third!60!black}{},
  },
  % ---- 横向变体: 根在左、向右延伸(grow'=east) ----
  % 宽树(多个 level-1 兄弟、节点含多行文字)顶向下排会超宽溢出页面;
  % 改用本式: 兄弟\emph{纵向}堆叠、树深\emph{横向}延伸,适配纵向 A4/16 开页面。
  % 用法同 navtree, 只把 \begin{forest} navtree 换成 \begin{forest} navtreeLR。
  navtreeLR/.style={
    for tree={
      grow'=east,
      draw, rounded corners, align=center, font=\small, inner sep=3pt,
      edge={->, thick, gray!60!black},
      parent anchor=east, child anchor=west,
      l sep=12mm, s sep=2.5mm,
    },
    where level=0{fill=main!6,  draw=main!60!black}{},
    where level=1{fill=second!6, draw=second!60!black}{},
    where level>=2{fill=third!8, draw=third!60!black}{},
  },
  % ---- 决策树: 横向(grow'=east)，根/枝/叶三色，结论叶(无子)高亮 ----
  % 把 codebox 里 ASCII 决策树(新任务 +- 问句? 是→… 否→…)改画成真图用本式:
  %   \begin{forest} dtree [根 [问句? [是→结论] [否→结论] ] … ] \end{forest}
  %   条件(是/否/任务特征)直接写进子节点文字，避免边标签，稳编译。
  dtree/.style={
    for tree={
      grow'=east, draw, rounded corners, align=left, font=\small,
      inner sep=3pt, edge={->, thick, gray!60!black},
      parent anchor=east, child anchor=west, l sep=11mm, s sep=2mm,
    },
    where level=0{fill=main!10, draw=main!65!black, font=\small\bfseries}{},
    where level>=1{fill=second!6, draw=second!55!black}{},
    where n children=0{fill=third!10, draw=third!60!black}{}, % 叶=推荐结论，高亮
  },
}
\endinput
